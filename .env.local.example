# Copy to .env.local and fill in your credentials
# .env.local is gitignored and must not be committed

# Supabase (required for data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: for address/city autocomplete in the hero search (get a public token at mapbox.com)
# Use MAPBOX_ACCESS_TOKEN (recommended; token stays on server) or NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here
